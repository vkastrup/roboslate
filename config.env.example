# RoboSlate configuration
# Copy this file to config.env and fill in your values.
# config.env is gitignored — never commit your API key.

#VISION_BACKEND=local

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Claude model for first-pass detection (fast/cheap).
# claude-haiku-4-5-20251001 = fast and cheap (good for batch work)
# claude-sonnet-4-6          = balanced accuracy and cost
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Model to escalate to when Haiku returns low confidence.
# Set equal to CLAUDE_MODEL to disable escalation.
ESCALATION_MODEL=claude-sonnet-4-6

# Max tokens for Claude response (slate JSON is small; 512 is plenty)
CLAUDE_MAX_TOKENS=512

# --- Scanning strategy ---
# Phase 1: scan first N seconds at X fps
SCAN_PHASE1_DURATION=60
SCAN_PHASE1_FPS=2

# Phase 2: scan last N seconds at X fps
SCAN_PHASE2_DURATION=30
SCAN_PHASE2_FPS=2

# Phase 3 (fallback if nothing found): full video, one frame every N seconds
SCAN_PHASE3_INTERVAL=5

# Hard cap on frames sent to Claude per video (cost guard)
MAX_FRAMES=16

# Stop scanning after this many consecutive slate frames detected (even if low confidence).
# Prevents scanning 40 frames on a difficult slate that never reaches high confidence.
CONSISTENT_READINGS_STOP=5

# Stop scanning as soon as a detection at this confidence level is found
# Values: high, medium
EARLY_STOP_CONFIDENCE=high

# --- Image settings ---
# Max image dimension (long edge) before sending to Claude
MAX_IMAGE_SIZE=1568

# JPEG quality for extracted frames (2-5 scale for ffmpeg -q:v; lower number = higher quality)
FRAME_JPEG_QUALITY=3

# --- SCRATCH integration ---
# Watch folder path for XML metadata write-back (SCRATCH polls this directory)
SCRATCH_WATCH_FOLDER=/Library/Application Support/Assimilator/WatchFolder

# --- Vision backend ---
# "claude" uses the Claude API (requires ANTHROPIC_API_KEY)
# "local" uses PaddleOCR — fully offline, no API key needed, lower accuracy
# Can also be overridden per-run with: --backend local
VISION_BACKEND=claude

# --- Batch processing ---
# Number of clips to process in parallel when using --batch.
# Each worker makes its own API calls; set to 1 to disable parallelism.
# Can also be overridden per-run with: --workers N
BATCH_WORKERS=4

# --- Logging ---
# Leave blank to use default: {project_dir}/logs/roboslate.log
# LOG_PATH=/var/log/roboslate.log

# --- Slate fields to extract ---
# Comment out any line to disable that field entirely.
# Disabled fields are excluded from the Claude prompt, merged result,
# terminal summary, JSON output, and CSV columns.
FIELD_scene=on
FIELD_take=on
FIELD_slate_number=on
FIELD_roll=on
FIELD_camera=on
FIELD_director=on
FIELD_dop=on
FIELD_production=on
FIELD_date=on
FIELD_fps=on
FIELD_format=on
FIELD_notes=on
