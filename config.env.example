# RoboSlate-arm configuration
# Copy to config.env and adjust as needed.
# No API key required — Apple Vision runs entirely on-device.

# ---------------------------------------------------------------------------
# Frame extraction
# ---------------------------------------------------------------------------

# Phase 1: scan the first N seconds of the clip at M fps
SCAN_PHASE1_DURATION=60
SCAN_PHASE1_FPS=2

# Phase 2: scan the last N seconds (in case slate is at end of take)
SCAN_PHASE2_DURATION=30
SCAN_PHASE2_FPS=2

# Phase 3: fallback — sparse scan every N seconds if phases 1 & 2 found nothing
SCAN_PHASE3_INTERVAL=5

# Maximum frames to scan per clip (limits OCR time on long clips)
MAX_FRAMES=16

# JPEG quality for extracted frames (1=best/slowest, 31=worst/fastest)
FRAME_JPEG_QUALITY=3

# ---------------------------------------------------------------------------
# Scan behaviour
# ---------------------------------------------------------------------------

# Stop early once this confidence level is achieved:
#   high   — stop as soon as one high-confidence slate is found (default)
#   medium — stop at medium or better
#   none   — scan all frames (same as --full-scan)
EARLY_STOP_CONFIDENCE=high

# Stop after this many consecutive slate-detecting frames
CONSISTENT_READINGS_STOP=5

# ---------------------------------------------------------------------------
# Batch processing
# ---------------------------------------------------------------------------

# Number of parallel workers for --batch (default: 1 = sequential)
# Apple Vision is CPU/Neural Engine bound — diminishing returns above ~4
BATCH_WORKERS=1

# ---------------------------------------------------------------------------
# Field selection (uncomment to enable specific fields only)
# ---------------------------------------------------------------------------
# If no FIELD_* lines are present, all fields are extracted (default).
# Uncomment and set to "on" to extract only specific fields:

FIELD_scene=on
FIELD_take=on
FIELD_slate_number=on
FIELD_roll=on
#FIELD_camera=on
#FIELD_director=on
#FIELD_dop=on
#FIELD_production=on
#FIELD_date=on
#FIELD_fps=on
#FIELD_format=on
FIELD_notes=on

# ---------------------------------------------------------------------------
# Resolve integration
# ---------------------------------------------------------------------------

# Parallel workers for the Resolve script (default: 1).
# WARNING: do NOT increase above 1 when ENABLE_VLM_ESCALATION=true —
# each subprocess loads the full MLX model and will exhaust RAM.
#RESOLVE_MAX_WORKERS=1

# ---------------------------------------------------------------------------
# MLX VLM escalation (optional, Apple Silicon only)
# ---------------------------------------------------------------------------
# Enables a local vision-language model as a last-resort pass when Apple
# Vision OCR is still low confidence after passes 1+2.
# Requires: venv/bin/pip install mlx-vlm  (or run setup.sh)
#
# VLM_MODEL accepts:
#   - A HuggingFace repo ID  → prompted to download on first interactive run;
#     model saved to mlx/models/<name>/ inside this project directory.
#   - A local absolute path  → loaded directly (no download).
#
# Recommended model: gemma-4-26b-a4b-it-4bit (~15 GB, best accuracy).
# Set VLM_MODEL to the local path if already downloaded, or to the
# HuggingFace repo ID to download on first run (prompted interactively).
#
# MLX_MODELS_DIR: where downloaded models are stored.
# Default: mlx/models/ inside this project directory.
#
#ENABLE_VLM_ESCALATION=false
#VLM_MODEL=mlx-community/gemma-4-26b-a4b-it-4bit
#VLM_MAX_TOKENS=300
#MLX_MODELS_DIR=mlx/models
